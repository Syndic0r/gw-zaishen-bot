# Copy to /etc/gw1-zaishen-bot.conf  (sudo chmod 600) — holds the bot token (SECRET, never commit).
# Referenced by gw1-zaishen-bot.service as EnvironmentFile.

# NOTE: this is read by systemd (EnvironmentFile) — put comments on their OWN line, never after a
# value. systemd keeps any inline text as PART of the value (which breaks the numeric IDs).

# bot token from the Discord Developer Portal (Bot -> Reset Token)
DISCORD_BOT_TOKEN=paste-your-bot-token-here

# The bot is multi-tenant: each server picks its channel + optional ping role in Discord with
# /setup, so the channel/role are no longer configured here. The three IDs below are OPTIONAL and
# only matter for the original single-server deployment:
#   - DISCORD_GUILD_ID gives instant slash-command sync in your dev/home server AND tells the
#     one-time migration which guild the pre-existing single-server data belongs to.
#   - DISCORD_ZAISHEN_CHANNEL_ID / DISCORD_PING_ROLE_ID seed that guild's /setup config on the
#     first multi-tenant startup, so it keeps posting to the same place. New servers ignore them.
# Leave them blank on a fresh install.
DISCORD_GUILD_ID=
DISCORD_ZAISHEN_CHANNEL_ID=
DISCORD_PING_ROLE_ID=

# seconds between bottom-of-channel re-checks (also how fast a new day is picked up). Default 60.
CHECK_INTERVAL=60
